{
  "name": "alexs-bootleg-terminal",
  "version": "1.0.0",
  "description": "Alex's Bootleg Terminal — SSH and Serial connection manager",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "vite": "vite",
    "electron": "electron ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serialport": "^12.0.0",
    "ssh2": "^1.16.0",
    "uuid": "^11.0.3",
    "@xterm/xterm": "^6.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0"
  },
  "build": {
    "appId": "com.alexsbootlegterminal.app",
    "productName": "Alex's Bootleg Terminal",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md,test,__tests__,tests,coverage,.github}",
      "!node_modules/.bin"
    ],
    "asarUnpack": [
      "node_modules/serialport/**/*",
      "node_modules/@serialport/**/*",
      "node_modules/node-gyp-build/**/*",
      "node_modules/bindings/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": { "category": "public.app-category.developer-tools" }
  }
}
